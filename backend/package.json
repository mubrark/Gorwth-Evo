{
  "name": "seo-backend",
  "version": "1.0.0",
  "description": "خادم SEO الخلفي - نظام إدارة الدفع والمستخدمين والنماذج",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm run server\" \"pnpm run client\"",
    "build": "tsc",
    "server": "nodemon --exec tsx ../backend/server.ts",
    "start": "nodemon dist/server.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "seo",
    "backend",
    "express",
    "stripe",
    "payment",
    "user-management"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "mysql2": "^3.6.5",
    "node.js": "0.0.1-security",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.1.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^6.4.14",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "dotenv": "^17.3.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.19.0",
    "nodemailer": "^8.0.7",
    "nodemon": "^3.1.14",
    "prettier": "^3.1.1",
    "stripe": "^17.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
